    }
}

component BackgroundChoiceRow inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <bool> selected: false;
    in property <bool> enabled: true;
    in property <float> ui-scale: 1;
    callback chosen();
    forward-focus: background-action;

    height: 70px * root.ui-scale;
    background: background-action.pressed ? #111111 : (root.selected ? #d9d7cd : #f7f6f0);
    border-width: (background-action.has-focus ? 4px : 1px) * root.ui-scale;
    border-color: #111111;
    accessible-role: button;
    accessible-label: root.title + ". " + root.detail + (root.selected ? ". Selected." : ". Tap to select.");
    accessible-enabled: root.enabled;

    HorizontalLayout {
        padding-left: 18px * root.ui-scale;
        padding-right: 18px * root.ui-scale;
        spacing: 14px * root.ui-scale;

        VerticalLayout {
            spacing: 0px;
