export enum ShellPage {
    home,
    sample,
    settings,
    maintenance,
}

export enum ConfirmationKind {
    none,
    reboot,
    power-off,
}

export enum AlertKind {
    none,
    application-unavailable,
    application-stopped,
    recovery-countdown,
}

export struct RegisteredApplication {
    title: string,
    detail: string,
    icon: image,
    available: bool,
}

export struct LauncherBackgroundOption {
    title: string,
    detail: string,
    selected: bool,
}

export global ShellData {
    in property <ShellPage> page: ShellPage.home;
    in property <ConfirmationKind> confirmation: ConfirmationKind.none;
    in property <AlertKind> alert: AlertKind.none;
    in property <int> recovery-seconds: 0;
    in property <string> profile-label: "PW1 · 758 × 1024 · host preview";
    in property <string> status-text: "L0 manual preview · device actions unavailable";
    in property <string> time-status: "9:41 AM";
    in property <string> timezone-status: "EDT";
    in property <int> sample-count: 0;
    in property <[RegisteredApplication]> applications: [];
    in property <image> launcher-background;
    in property <string> launcher-background-label: "Pattern";
    in property <[LauncherBackgroundOption]> launcher-background-options: [];
    in property <string> active-application-title: "Application";
    in property <int> battery-percent: 96;
    in property <bool> battery-charging: false;
    in property <string> battery-status: "96%";
    in property <string> network-status: "Wi-Fi";
    in property <int> frontlight-level: 11;
    in property <int> warmth-level: 19;
    in property <bool> auto-brightness: false;
    in property <bool> display-controls-available: true;
    in property <string> bluetooth-status: "Off";
    in property <string> ssh-status: "On";
    in property <string> usbnet-status: "On";
    in property <string> device-adapter-status: "PREVIEW";
    in property <string> storage-status: "NOT CHECKED";
    in property <bool> storage-warning: false;
    in property <bool> literary-clock-available: true;
    in property <bool> literary-clock-enabled: true;
    in property <string> literary-clock-interval-label: "Every minute";
    in property <bool> literary-clock-has-excerpt: true;
    in property <styled-text> literary-excerpt: @markdown("By **9:41**, the room was quiet enough for another chapter.");
    in property <string> literary-credit: "— ferrink preview";
    in property <int> literary-excerpt-font-size: 30;
}

export global ShellActions {
    callback return-home();
    callback launch-application(int);
    callback open-sample();
    callback open-settings();
    callback open-maintenance();
    callback request-stock();
    callback request-reboot();
    callback request-power-off();
    callback confirm-power-action();
    callback cancel-power-action();
    callback dismiss-alert();
    callback increment-sample();
    callback adjust-frontlight(int);
    callback adjust-warmth(int);
    callback set-frontlight(int);
    callback set-warmth(int);
    callback toggle-wifi();
    callback cycle-literary-clock-interval();
    callback select-launcher-background(int);
}

component ActionArea inherits FocusScope {
    private property <bool> key-pressed-state: false;
    out property <bool> pressed: action-touch.pressed || root.key-pressed-state;
    callback activated();

    key-pressed(event) => {
        if root.enabled && (event.text == " " || event.text == Key.Return) {
            if !root.key-pressed-state {
                root.key-pressed-state = true;
                root.activated();
            }
            return accept;
        }
        reject
    }

    key-released(event) => {
        if event.text == " " || event.text == Key.Return {
            root.key-pressed-state = false;
            return accept;
        }
        reject
    }

    action-touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? pointer : default;
        clicked => {
            root.focus();
            root.activated();
        }
    }
}

// Slint's software renderer intentionally omits blurred drop shadows. One
// offset copy gives Home labels a crisp E Ink-safe shadow without making the
// letterforms look hollow.
component HaloedApplicationLabel inherits Rectangle {
    in property <string> text;
    in property <float> ui-scale: 1;
    in property <bool> enabled: true;
    background: transparent;

    Text {
        x: 1px * root.ui-scale;
        y: 1px * root.ui-scale;
        width: parent.width;
        height: parent.height;
        text: root.text;
        color: #111111;
        font-size: 24px * root.ui-scale;
        font-weight: 750;
        horizontal-alignment: center;
        vertical-alignment: center;
        wrap: word-wrap;
        overflow: elide;
        max-lines: 2;
    }

    Text {
        width: parent.width;
        height: parent.height;
        text: root.text;
        color: root.enabled ? #f7f6f0 : #d4d2ca;
        font-size: 24px * root.ui-scale;
        font-weight: 750;
        horizontal-alignment: center;
        vertical-alignment: center;
        wrap: word-wrap;
        overflow: elide;
        max-lines: 2;
    }
}

component HaloedLiteraryExcerpt inherits Rectangle {
    in property <styled-text> text;
    in property <float> ui-scale: 1;
