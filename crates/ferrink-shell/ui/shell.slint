component ApplicationTile inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <image> icon;
    in property <float> ui-scale: 1;
    in property <bool> enabled: true;
    in property <int> focus-request: 0;
    callback activated();
    forward-focus: nav-action;

    changed focus-request => {
        if root.focus-request > 0 && root.enabled { nav-action.focus(); }
    }
    init => {
        if root.focus-request > 0 && root.enabled { nav-action.focus(); }
    }

    width: 298px * root.ui-scale;
    height: 220px * root.ui-scale;
    background: transparent;
    accessible-role: button;
    accessible-label: root.title + ". " + root.detail;
    accessible-enabled: root.enabled;

    VerticalLayout {
        alignment: center;
        spacing: 12px * root.ui-scale;

        HorizontalLayout {
            height: 154px * root.ui-scale;
            spacing: 0px;

            Rectangle { horizontal-stretch: 1; }
            Rectangle {
                width: 154px * root.ui-scale;
                background: nav-action.pressed ? #111111 : (root.enabled ? #f7f6f0 : #dedcd3);
                border-width: (nav-action.has-focus ? 5px : 2px) * root.ui-scale;
                border-color: #111111;
                border-radius: 28px * root.ui-scale;

                Image {
                    x: 22px * root.ui-scale;
                    y: 22px * root.ui-scale;
                    width: parent.width - 44px * root.ui-scale;
                    height: parent.height - 44px * root.ui-scale;
                    source: root.icon;
                    colorize: nav-action.pressed ? white : (root.enabled ? #111111 : #777773);
                    image-fit: contain;
                }
            }
            Rectangle { horizontal-stretch: 1; }
        }

        HaloedApplicationLabel {
            height: 54px * root.ui-scale;
            text: root.title;
            ui-scale: root.ui-scale;
            enabled: root.enabled;
        }
    }

    nav-action := ActionArea {
        enabled: root.enabled;
        activated => { root.activated(); }
    }

    accessible-action-default => {
        if root.enabled { root.activated(); }
    }
}

component CompactButton inherits Rectangle {
    in property <string> label;
    in property <float> ui-scale: 1;
    in property <bool> dark: false;
    in property <bool> enabled: true;
    in property <int> focus-request: 0;
    callback activated();
    forward-focus: button-action;

    changed focus-request => {
        if root.focus-request > 0 && root.enabled { button-action.focus(); }
    }
    init => {
        if root.focus-request > 0 && root.enabled { button-action.focus(); }
    }

    height: 60px * root.ui-scale;
    vertical-stretch: 0;
    background: transparent;
    accessible-role: button;
    accessible-label: root.label;
    accessible-enabled: root.enabled;

    control-surface := Rectangle {
        height: parent.height;
        background: button-action.pressed ? (root.dark ? #f7f6f0 : #111111) : (root.enabled ? (root.dark ? #111111 : #f7f6f0) : #dedcd3);
        border-width: (button-action.has-focus ? 4px : 2px) * root.ui-scale;
        border-color: #111111;
        border-radius: 8px * root.ui-scale;

        Text {
            text: root.label;
            color: button-action.pressed ? (root.dark ? #111111 : white) : (root.enabled ? (root.dark ? white : #111111) : #777773);
            font-size: 22px * root.ui-scale;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    button-action := ActionArea {
        enabled: root.enabled;
        activated => { root.activated(); }
    }

    accessible-action-default => {
        if root.enabled { root.activated(); }
    }
}

component QuickAction inherits Rectangle {
    in property <string> symbol;
    in property <string> label;
    in property <string> state;
    in property <float> ui-scale: 1;
    in property <bool> enabled: true;
    callback activated();
    forward-focus: quick-action;

    height: 88px * root.ui-scale;
    background: transparent;
    accessible-role: button;
    accessible-label: root.label;
    accessible-enabled: root.enabled;

    VerticalLayout {
        padding-top: 5px * root.ui-scale;
        padding-bottom: 4px * root.ui-scale;
        spacing: 1px * root.ui-scale;

        Rectangle {
            height: 42px * root.ui-scale;
            background: transparent;

            Rectangle {
                x: (parent.width - self.width) / 2;
                width: 42px * root.ui-scale;
                background: quick-action.pressed ? #111111 : transparent;
                border-width: (quick-action.has-focus ? 3px : 2px) * root.ui-scale;
                border-color: root.enabled ? #111111 : #777773;
                border-radius: 21px * root.ui-scale;

                Text {
                    text: root.symbol;
                    color: quick-action.pressed ? white : (root.enabled ? #111111 : #777773);
                    font-size: 20px * root.ui-scale;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
        Text {
            text: root.label;
            color: root.enabled ? #111111 : #777773;
            font-size: 16px * root.ui-scale;
            font-weight: 750;
            horizontal-alignment: center;
        }
        Text {
            text: root.state;
            color: #4b4a46;
            font-size: 12px * root.ui-scale;
            horizontal-alignment: center;
        }
    }

    quick-action := ActionArea {
        enabled: root.enabled;
        activated => { root.activated(); }
    }
}

component LevelControl inherits Rectangle {
    in property <string> label;
    in property <int> value;
    in property <int> maximum: 24;
    in property <float> ui-scale: 1;
    in property <bool> enabled: true;
    callback decrease();
    callback increase();
    callback changed(int);
    private property <int> drag-value: root.value;

    height: 92px * root.ui-scale;
    background: transparent;

    VerticalLayout {
        padding-left: 2px * root.ui-scale;
        padding-right: 2px * root.ui-scale;
        padding-top: 4px * root.ui-scale;
        padding-bottom: 2px * root.ui-scale;
        spacing: 2px * root.ui-scale;

        HorizontalLayout {
            Text {
                text: root.label;
                color: root.enabled ? #111111 : #4b4a46;
                font-size: 16px * root.ui-scale;
                font-weight: 750;
            }
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: "\{root.value}";
                color: #4b4a46;
                font-size: 16px * root.ui-scale;
                font-weight: 700;
            }
        }

        HorizontalLayout {
            spacing: 4px * root.ui-scale;

            Rectangle {
                width: 54px * root.ui-scale;
                background: decrease-action.pressed ? #111111 : transparent;
                accessible-role: button;
                accessible-label: "Decrease " + root.label;

                Text {
                    text: "−";
                    color: decrease-action.pressed ? white : (root.enabled ? #111111 : #777773);
                    font-size: 28px * root.ui-scale;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                decrease-action := ActionArea {
                    enabled: root.enabled;
                    activated => { root.decrease(); }
                }
            }

            Rectangle {
                horizontal-stretch: 1;
                background: transparent;

                Rectangle {
                    x: 12px * root.ui-scale;
                    y: (parent.height - self.height) / 2;
                    width: parent.width - 24px * root.ui-scale;
                    height: 5px * root.ui-scale;
                    background: #c9c9c4;

                    Rectangle {
                        width: parent.width * (slider-touch.pressed ? root.drag-value : root.value) / root.maximum;
                        background: root.enabled ? #111111 : #777773;
                    }
                }

                handle := Rectangle {
                    width: 22px * root.ui-scale;
                    height: 34px * root.ui-scale;
                    x: (parent.width - self.width) * (slider-touch.pressed ? root.drag-value : root.value) / root.maximum;
                    y: (parent.height - self.height) / 2;
                    border-radius: 5px * root.ui-scale;
                    border-width: 3px * root.ui-scale;
                    border-color: root.enabled ? #111111 : #777773;
                    background: slider-touch.pressed ? #111111 : #f7f6f0;
                }

                slider-touch := TouchArea {
                    enabled: root.enabled;
                    accessible-role: slider;
                    accessible-label: root.label;
                    accessible-value: "\{slider-touch.pressed ? root.drag-value : root.value}";

                    pointer-event(event) => {
                        if event.button == PointerEventButton.left && event.kind == PointerEventKind.down {
                            root.drag-value = round(root.maximum * max(0, min(1, self.mouse-x / self.width)));
                        } else if event.button == PointerEventButton.left && event.kind == PointerEventKind.up {
                            root.drag-value = round(root.maximum * max(0, min(1, self.mouse-x / self.width)));
                            root.changed(root.drag-value);
                        }
                    }

                    moved => {
                        if self.enabled && self.pressed {
                            root.drag-value = round(root.maximum * max(0, min(1, self.mouse-x / self.width)));
                        }
                    }
                }
            }

            Rectangle {
                width: 54px * root.ui-scale;
                background: increase-action.pressed ? #111111 : transparent;
                accessible-role: button;
                accessible-label: "Increase " + root.label;

                Text {
                    text: "+";
                    color: increase-action.pressed ? white : (root.enabled ? #111111 : #777773);
                    font-size: 28px * root.ui-scale;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                increase-action := ActionArea {
                    enabled: root.enabled;
                    activated => { root.increase(); }
                }
            }
        }
    }
}

