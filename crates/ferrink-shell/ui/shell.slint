            Text {
                text: root.detail;
                color: background-action.pressed ? white : #4b4a46;
                font-size: 15px * root.ui-scale;
                vertical-alignment: center;
            }
        }

        Rectangle { horizontal-stretch: 1; }

        Text {
            text: root.selected ? "SELECTED" : "SELECT";
            color: background-action.pressed ? white : (root.selected ? #111111 : #4b4a46);
            font-size: 14px * root.ui-scale;
            font-weight: 800;
            letter-spacing: 1px * root.ui-scale;
            vertical-alignment: center;
        }
    }

    background-action := ActionArea {
        enabled: root.enabled;
        activated => { root.chosen(); }
    }

    accessible-action-default => {
        if root.enabled { root.chosen(); }
    }
}

export component ShellWindow inherits Window {
    title: "ferrink";
    default-font-family: "Inter Variable";
    preferred-width: 758px;
    preferred-height: 1024px;
    min-width: 600px;
    min-height: 800px;
    background: #eeece3;
    in property <float> ui-scale: 1;
    in-out property <int> focus-generation: 0;
    in-out property <bool> quick-settings-open: false;
    in-out property <bool> background-picker-open: false;
    private property <bool> blocking-modal-visible: ShellData.confirmation != ConfirmationKind.none || ShellData.alert != AlertKind.none;

    private property <bool> modal-visible: root.quick-settings-open || root.blocking-modal-visible;

    public function focus-keyboard-root() {
        keyboard-scope.focus();
    }

    keyboard-scope := FocusScope {
        focus-on-tab-navigation: false;
        key-pressed(event) => {
            if event.text == Key.Escape {
                if root.quick-settings-open {
                    root.quick-settings-open = false;
                } else if root.background-picker-open {
                    root.background-picker-open = false;
                } else if ShellData.confirmation != ConfirmationKind.none {
                    ShellActions.cancel-power-action();
                } else if ShellData.alert == AlertKind.application-unavailable || ShellData.alert == AlertKind.application-stopped {
                    ShellActions.dismiss-alert();
                } else if ShellData.alert == AlertKind.recovery-countdown {
                    // Recovery is fail-safe and cannot be dismissed from the keyboard.
                } else if ShellData.page != ShellPage.home {
                    ShellActions.return-home();
                } else {
                    return reject;
                }
                return accept;
            }
            reject
        }

        VerticalLayout {
            spacing: 0px;

        if ShellData.page == ShellPage.home : top-bar := Rectangle {
            height: 54px * root.ui-scale;
            background: #f7f6f0;

            HorizontalLayout {
                padding-left: 18px * root.ui-scale;
                padding-right: 18px * root.ui-scale;
                spacing: 12px * root.ui-scale;

                Text {
                    text: ShellData.time-status;
                    color: #111111;
                    font-size: 17px * root.ui-scale;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                Text {
                    text: ShellData.network-status;
                    color: #111111;
                    font-size: 14px * root.ui-scale;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                Text {
                    text: ShellData.battery-status;
                    color: #111111;
                    font-size: 17px * root.ui-scale;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                Rectangle {
                    width: 34px * root.ui-scale;
                    background: transparent;

                    Rectangle {
                        y: (parent.height - self.height) / 2;
                        width: 31px * root.ui-scale;
                        height: 17px * root.ui-scale;
                        background: transparent;
                        border-width: 2px * root.ui-scale;
                        border-color: #111111;
                        border-radius: 2px * root.ui-scale;

                        Rectangle {
                            x: 3px * root.ui-scale;
                            y: 3px * root.ui-scale;
                            width: (parent.width - 6px * root.ui-scale) * ShellData.battery-percent / 100;
                            height: parent.height - 6px * root.ui-scale;
                            background: #111111;
                        }

                        Rectangle {
                            x: parent.width;
                            y: 5px * root.ui-scale;
                            width: 3px * root.ui-scale;
                            height: 7px * root.ui-scale;
                            background: #111111;
                        }
                    }
                }
            }

            settings-handle := ActionArea {
                x: (parent.width - self.width) / 2;
                y: 0px;
                width: 150px * root.ui-scale;
                height: parent.height;
                enabled: !root.blocking-modal-visible;
                accessible-role: button;
                accessible-label: "Quick settings";
                activated => { root.quick-settings-open = !root.quick-settings-open; }

                Path {
                    x: 28px * root.ui-scale;
                    y: 15px * root.ui-scale;
                    width: 94px * root.ui-scale;
                    height: 24px * root.ui-scale;
                    viewbox-width: 100;
                    viewbox-height: 20;
                    stroke: #111111;
                    stroke-width: 5px * root.ui-scale;
                    stroke-line-cap: round;
                    stroke-line-join: round;

                    MoveTo { x: 4; y: root.quick-settings-open ? 16 : 4; }
                    LineTo { x: 50; y: root.quick-settings-open ? 4 : 16; }
                    LineTo { x: 96; y: root.quick-settings-open ? 16 : 4; }
                }
            }
        }

        if ShellData.page == ShellPage.home : home-page := Rectangle {
            vertical-stretch: 1;
            background: #eeece3;

            Image {
                width: parent.width;
                height: parent.height;
                source: ShellData.launcher-background;
                image-fit: cover;
            }

            VerticalLayout {
                padding-left: 34px * root.ui-scale;
                padding-right: 34px * root.ui-scale;
                padding-top: 22px * root.ui-scale;
                padding-bottom: 24px * root.ui-scale;
                spacing: 16px * root.ui-scale;

                app-grid := GridLayout {
                    height: ((ShellData.applications.length + 1) / 2) * 220px * root.ui-scale;
                    spacing: 16px * root.ui-scale;

                    Row {
                        for application[index] in ShellData.applications : ApplicationTile {
                            row: index / 2;
                            col: mod(index, 2);
                            title: application.title;
                            detail: application.detail;
                            icon: application.icon;
                            ui-scale: root.ui-scale;
                            enabled: !root.modal-visible && application.available;
                            focus-request: index == 0 ? root.focus-generation : 0;
                            activated => { ShellActions.launch-application(index); }
                        }
                    }
                }

                if ShellData.literary-clock-enabled && ShellData.literary-clock-has-excerpt : literary-clock := Rectangle {
                    vertical-stretch: 1;
                    background: transparent;

                    HaloedLiteraryExcerpt {
                        x: 30px * root.ui-scale;
                        y: 10px * root.ui-scale;
                        width: parent.width - 60px * root.ui-scale;
                        height: parent.height - 90px * root.ui-scale;
                        text: ShellData.literary-excerpt;
                        font-size: ShellData.literary-excerpt-font-size;
                        ui-scale: root.ui-scale;
                    }

                    HaloedCredit {
                        x: 30px * root.ui-scale;
                        y: parent.height - 66px * root.ui-scale;
                        width: parent.width - 60px * root.ui-scale;
                        height: 52px * root.ui-scale;
                        text: ShellData.literary-credit;
                        ui-scale: root.ui-scale;
                    }
                }

                if !ShellData.literary-clock-enabled || !ShellData.literary-clock-has-excerpt : Rectangle {
                    vertical-stretch: 1;
                }
            }
        }

        if ShellData.page == ShellPage.sample : sample-page := Rectangle {
            vertical-stretch: 1;
            background: #eeece3;

            VerticalLayout {
                spacing: 0px;

                sample-back := BackBar {
                    title: "Sample app";
                    ui-scale: root.ui-scale;
                    enabled: !root.modal-visible;
                    focus-request: root.focus-generation;
                    back => { ShellActions.return-home(); }
                }

                VerticalLayout {
                    padding-left: 42px * root.ui-scale;
                    padding-right: 42px * root.ui-scale;
                    padding-top: 32px * root.ui-scale;
                    padding-bottom: 32px * root.ui-scale;
                    spacing: 22px * root.ui-scale;

                    Text {
                        text: "Ink, measured.";
                        color: #111111;
                        font-size: 48px * root.ui-scale;
                        font-weight: 800;
                    }

                    Text {
                        text: "A software-renderer test surface for hierarchy, tone, and real callbacks.";
                        color: #4b4a46;
                        font-size: 21px * root.ui-scale;
                        wrap: word-wrap;
                    }

                    Rectangle {
                        height: 250px * root.ui-scale;
                        border-width: 2px * root.ui-scale;
                        border-color: #111111;

                        HorizontalLayout {
                            spacing: 0px;
                            Rectangle { background: white; horizontal-stretch: 1; }
                            Rectangle { background: #c9c9c4; horizontal-stretch: 1; }
                            Rectangle { background: #777773; horizontal-stretch: 1; }
                            Rectangle { background: #111111; horizontal-stretch: 1; }
                        }
                    }

                    Rectangle { vertical-stretch: 1; }

                    Text {
                        text: "CALLBACK COUNT";
                        color: #4b4a46;
                        font-size: 14px * root.ui-scale;
                        font-weight: 700;
                        letter-spacing: 2px * root.ui-scale;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "\{ShellData.sample-count}";
                        color: #111111;
                        font-size: 68px * root.ui-scale;
                        font-weight: 800;
                        horizontal-alignment: center;
                    }

                    sample-increment := CompactButton {
                        label: "Run callback";
                        ui-scale: root.ui-scale;
                        dark: true;
                        enabled: !root.modal-visible;
                        activated => { ShellActions.increment-sample(); }
                    }
                }
            }
        }

        if ShellData.page == ShellPage.settings && !root.background-picker-open : settings-page := Rectangle {
            vertical-stretch: 1;
            background: #eeece3;

            VerticalLayout {
                spacing: 0px;

                settings-back := BackBar {
                    title: "Device settings";
                    ui-scale: root.ui-scale;
                    enabled: !root.modal-visible;
                    focus-request: root.focus-generation;
                    back => { ShellActions.return-home(); }
                }

                settings-scroll := Flickable {
                    viewport-width: self.width;
                    viewport-height: settings-content.height;

                    settings-content := VerticalLayout {
                        width: settings-scroll.width;
                        height: 1220px * root.ui-scale;
                        padding-left: 34px * root.ui-scale;
                        padding-right: 34px * root.ui-scale;
                        padding-top: 20px * root.ui-scale;
                        padding-bottom: 22px * root.ui-scale;
                        spacing: 8px * root.ui-scale;

                        Text {
                            text: "Display";
                            color: #111111;
                            font-size: 25px * root.ui-scale;
                            font-weight: 800;
                        }
                        StatusRow { label: "Front light"; value: "\{ShellData.frontlight-level} / 24"; ui-scale: root.ui-scale; }
                        StatusRow { label: "Warmth"; value: "\{ShellData.warmth-level} / 24"; ui-scale: root.ui-scale; }
                        StatusRow { label: "Auto brightness"; value: ShellData.auto-brightness ? "ON" : "OFF"; ui-scale: root.ui-scale; }
                        SettingChoiceRow {
                            label: "Background";
                            value: ShellData.launcher-background-label;
                            enabled: !root.modal-visible && ShellData.launcher-background-options.length > 1;
                            ui-scale: root.ui-scale;
                            selected => { root.background-picker-open = true; }
                        }
                        SettingChoiceRow {
                            label: "Literary clock";
                            value: ShellData.literary-clock-interval-label;
                            enabled: !root.modal-visible && ShellData.literary-clock-available;
                            ui-scale: root.ui-scale;
                            selected => { ShellActions.cycle-literary-clock-interval(); }
                        }

                        Text {
                            text: "Date & time";
                            color: #111111;
                            font-size: 25px * root.ui-scale;
                            font-weight: 800;
                        }
                        StatusRow { label: "Local time"; value: ShellData.time-status; ui-scale: root.ui-scale; }
                        StatusRow { label: "Time zone"; value: ShellData.timezone-status; ui-scale: root.ui-scale; }

                        Text {
                            text: "Connections";
                            color: #111111;
                            font-size: 25px * root.ui-scale;
                            font-weight: 800;
                        }
                        StatusRow { label: "Wi-Fi"; value: ShellData.network-status; ui-scale: root.ui-scale; }
                        StatusRow { label: "Bluetooth"; value: ShellData.bluetooth-status; ui-scale: root.ui-scale; }
                        StatusRow { label: "SSH"; value: ShellData.ssh-status; ui-scale: root.ui-scale; }
                        StatusRow { label: "USB network"; value: ShellData.usbnet-status; ui-scale: root.ui-scale; }

                        Rectangle { vertical-stretch: 1; }

                        HorizontalLayout {
                            height: 62px * root.ui-scale;
                            spacing: 8px * root.ui-scale;

                            CompactButton {
                                horizontal-stretch: 1;
                                label: "Amazon home";
                                ui-scale: root.ui-scale;
                                enabled: !root.modal-visible;
                                activated => { ShellActions.request-stock(); }
                            }
                            CompactButton {
                                horizontal-stretch: 1;
                                label: "Restart";
                                ui-scale: root.ui-scale;
                                enabled: !root.modal-visible;
                                activated => { ShellActions.request-reboot(); }
                            }
                            CompactButton {
                                horizontal-stretch: 1;
                                label: "Power off";
                                ui-scale: root.ui-scale;
                                enabled: !root.modal-visible;
                                activated => { ShellActions.request-power-off(); }
                            }
                        }
                    }
                }
            }
        }

        if ShellData.page == ShellPage.settings && root.background-picker-open : background-picker-page := Rectangle {
            vertical-stretch: 1;
            background: #eeece3;

            VerticalLayout {
                spacing: 0px;

                background-picker-back := BackBar {
                    title: "Background";
                    ui-scale: root.ui-scale;
                    enabled: !root.modal-visible;
                    focus-request: root.focus-generation;
                    back => { root.background-picker-open = false; }
                }

                background-picker-scroll := Flickable {
                    viewport-width: self.width;
                    viewport-height: max(self.height, (ShellData.launcher-background-options.length * 78 + 42) * 1px * root.ui-scale);

                    VerticalLayout {
                        width: background-picker-scroll.width;
                        height: background-picker-scroll.viewport-height;
                        padding-left: 34px * root.ui-scale;
                        padding-right: 34px * root.ui-scale;
                        padding-top: 20px * root.ui-scale;
                        padding-bottom: 22px * root.ui-scale;
                        spacing: 8px * root.ui-scale;

                        for option[index] in ShellData.launcher-background-options : BackgroundChoiceRow {
                            title: option.title;
                            detail: option.detail;
                            selected: option.selected;
                            enabled: !root.modal-visible;
                            ui-scale: root.ui-scale;
                            chosen => { ShellActions.select-launcher-background(index); }
                        }

                        Rectangle { vertical-stretch: 1; }
                    }
                }
            }
        }

        if ShellData.page == ShellPage.maintenance : maintenance-page := Rectangle {
            vertical-stretch: 1;
            background: #eeece3;

            VerticalLayout {
                spacing: 0px;

                maintenance-back := BackBar {
                    title: "Maintenance";
                    ui-scale: root.ui-scale;
                    enabled: !root.modal-visible;
                    focus-request: root.focus-generation;
                    back => { ShellActions.return-home(); }
                }

                VerticalLayout {
                    padding-left: 42px * root.ui-scale;
                    padding-right: 42px * root.ui-scale;
                    padding-top: 34px * root.ui-scale;
                    padding-bottom: 34px * root.ui-scale;
                    spacing: 0px;

                    Text {
                        text: "Safety boundary";
                        color: #111111;
                        font-size: 42px * root.ui-scale;
                        font-weight: 800;
                    }

                    Text {
                        text: "This build is intentionally unable to control a Kindle.";
                        color: #4b4a46;
                        font-size: 20px * root.ui-scale;
                    }

                    Rectangle { height: 24px * root.ui-scale; }

                    StatusRow { label: "Authority"; value: "L0 / MANUAL"; ui-scale: root.ui-scale; }
                    StatusRow { label: "Device adapter"; value: ShellData.device-adapter-status; ui-scale: root.ui-scale; }
                    StatusRow { label: "System commands"; value: "INERT"; ui-scale: root.ui-scale; }
                    StatusRow { label: "Battery"; value: ShellData.battery-status; ui-scale: root.ui-scale; }
                    StatusRow { label: "Network"; value: ShellData.network-status; ui-scale: root.ui-scale; }
                    StatusRow {
                        label: "Storage";
                        value: ShellData.storage-status;
                        warning: ShellData.storage-warning;
                        ui-scale: root.ui-scale;
                    }
                    StatusRow { label: "Preview geometry"; value: ShellData.profile-label; ui-scale: root.ui-scale; }

                    Rectangle { vertical-stretch: 1; }
                }
            }
        }

        if ShellData.status-text != "" : status-bar := Rectangle {
            height: 50px * root.ui-scale;
            background: #d9d7cd;
            border-width: 2px * root.ui-scale;
            border-color: #111111;

            HorizontalLayout {
                padding-left: 26px * root.ui-scale;
                padding-right: 26px * root.ui-scale;

                Text {
                    text: ShellData.status-text;
                    color: #111111;
                    font-size: 16px * root.ui-scale;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
        }
    }

    if root.quick-settings-open : quick-settings-dismiss := TouchArea {
        x: 0px;
        y: 54px * root.ui-scale;
        width: root.width;
        height: root.height - self.y;
        z: 20;
        clicked => { root.quick-settings-open = false; }
    }

    if root.quick-settings-open : quick-settings-sheet := Rectangle {
        x: 0px;
        y: 54px * root.ui-scale;
        width: root.width;
        height: 392px * root.ui-scale;
        z: 30;
        background: #f7f6f0;

        TouchArea { }

        VerticalLayout {
            padding-left: 24px * root.ui-scale;
            padding-right: 24px * root.ui-scale;
            padding-top: 10px * root.ui-scale;
            padding-bottom: 8px * root.ui-scale;
            spacing: 5px * root.ui-scale;

            HorizontalLayout {
                spacing: 20px * root.ui-scale;

                QuickAction {
                    horizontal-stretch: 1;
                    symbol: "W";
                    label: "Wi-Fi";
                    state: ShellData.network-status;
                    ui-scale: root.ui-scale;
                    activated => { ShellActions.toggle-wifi(); }
                }
                QuickAction {
                    horizontal-stretch: 1;
                    symbol: "B";
                    label: "Bluetooth";
                    state: ShellData.bluetooth-status;
                    ui-scale: root.ui-scale;
                    enabled: false;
                }
                QuickAction {
                    horizontal-stretch: 1;
                    symbol: "⋮";
                    label: "All settings";
                    state: "Open";
                    ui-scale: root.ui-scale;
                    activated => {
                        root.quick-settings-open = false;
                        ShellActions.open-settings();
                    }
                }
            }

            Rectangle {
                height: 1px * root.ui-scale;
                background: #c9c9c4;
            }

            LevelControl {
                label: "Brightness";
                value: ShellData.frontlight-level;
                ui-scale: root.ui-scale;
                enabled: ShellData.display-controls-available;
                decrease => { ShellActions.adjust-frontlight(-1); }
                increase => { ShellActions.adjust-frontlight(1); }
                changed(value) => { ShellActions.set-frontlight(value); }
            }
            LevelControl {
                label: "Warmth";
                value: ShellData.warmth-level;
                ui-scale: root.ui-scale;
                enabled: ShellData.display-controls-available;
                decrease => { ShellActions.adjust-warmth(-1); }
                increase => { ShellActions.adjust-warmth(1); }
                changed(value) => { ShellActions.set-warmth(value); }
            }

            Rectangle { vertical-stretch: 1; }

            close-sheet := ActionArea {
                height: 42px * root.ui-scale;
                activated => { root.quick-settings-open = false; }

                Path {
                    x: (parent.width - self.width) / 2;
                    y: 8px * root.ui-scale;
                    width: 94px * root.ui-scale;
                    height: 24px * root.ui-scale;
                    viewbox-width: 100;
                    viewbox-height: 20;
                    stroke: #111111;
                    stroke-width: 5px * root.ui-scale;
                    stroke-line-cap: round;
                    stroke-line-join: round;

                    MoveTo { x: 4; y: 16; }
                    LineTo { x: 50; y: 4; }
                    LineTo { x: 96; y: 16; }
                }
            }
        }
    }

    if ShellData.confirmation != ConfirmationKind.none : confirmation-overlay := Rectangle {
        background: #d9d7cd;

        VerticalLayout {
            padding-left: 56px * root.ui-scale;
            padding-right: 56px * root.ui-scale;
            padding-top: 90px * root.ui-scale;
            padding-bottom: 90px * root.ui-scale;

            Rectangle { vertical-stretch: 1; }

            Rectangle {
                height: 480px * root.ui-scale;
                background: #f7f6f0;
                border-width: 4px * root.ui-scale;
                border-color: #111111;

                VerticalLayout {
                    padding-left: 38px * root.ui-scale;
                    padding-right: 38px * root.ui-scale;
                    padding-top: 34px * root.ui-scale;
                    padding-bottom: 34px * root.ui-scale;
                    spacing: 20px * root.ui-scale;

                    Text {
                        text: "CONFIRM SYSTEM ACTION";
                        color: #4b4a46;
                        font-size: 15px * root.ui-scale;
                        font-weight: 700;
                        letter-spacing: 2px * root.ui-scale;
                    }

                    Text {
                        text: ShellData.confirmation == ConfirmationKind.reboot ? "Reboot device?" : "Power off device?";
                        color: #111111;
                        font-size: 43px * root.ui-scale;
                        font-weight: 800;
                    }

                    Text {
                        text: ShellData.confirmation == ConfirmationKind.reboot
                            ? "Your Kindle will turn off and start again. This may take a minute."
                            : "Your Kindle will turn off. Use the power button when you want to turn it back on.";
                        color: #4b4a46;
                        font-size: 21px * root.ui-scale;
                        wrap: word-wrap;
                    }

                    Rectangle { vertical-stretch: 1; }

                    confirm-button := CompactButton {
                        label: ShellData.confirmation == ConfirmationKind.reboot ? "Confirm reboot" : "Confirm power off";
                        ui-scale: root.ui-scale;
                        dark: true;
                        activated => { ShellActions.confirm-power-action(); }
                    }

                    cancel-button := CompactButton {
                        label: "Cancel";
                        ui-scale: root.ui-scale;
                        focus-request: root.focus-generation;
                        activated => { ShellActions.cancel-power-action(); }
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }
        }
    }

    if ShellData.alert != AlertKind.none : alert-overlay := Rectangle {
        background: #d9d7cd;

        VerticalLayout {
            padding-left: 56px * root.ui-scale;
            padding-right: 56px * root.ui-scale;
            padding-top: 72px * root.ui-scale;
            padding-bottom: 72px * root.ui-scale;

            Rectangle { vertical-stretch: 1; }

            Rectangle {
                height: (ShellData.alert == AlertKind.recovery-countdown ? 540px : 440px) * root.ui-scale;
                background: #f7f6f0;
                border-width: 4px * root.ui-scale;
                border-color: #111111;

                VerticalLayout {
                    padding-left: 38px * root.ui-scale;
                    padding-right: 38px * root.ui-scale;
                    padding-top: 32px * root.ui-scale;
                    padding-bottom: 32px * root.ui-scale;
                    spacing: 16px * root.ui-scale;

                    Text {
                        text: ShellData.alert == AlertKind.recovery-countdown ? "SAFE RECOVERY" : "APPLICATION STATUS";
                        color: #4b4a46;
                        font-size: 15px * root.ui-scale;
                        font-weight: 700;
                        letter-spacing: 2px * root.ui-scale;
                    }

                    Text {
                        text: ShellData.alert == AlertKind.application-unavailable
                            ? "App unavailable"
                            : ShellData.alert == AlertKind.application-stopped
                                ? "App stopped"
                                : "Returning to Kindle";
                        color: #111111;
                        font-size: 41px * root.ui-scale;
                        font-weight: 800;
                        wrap: word-wrap;
                        overflow: elide;
                        max-lines: 2;
                    }

                    if ShellData.alert != AlertKind.recovery-countdown : Text {
                        text: ShellData.active-application-title;
                        color: #111111;
                        font-size: 23px * root.ui-scale;
                        font-weight: 700;
                        wrap: word-wrap;
                        overflow: elide;
                        max-lines: 2;
                    }

                    Text {
                        text: ShellData.alert == AlertKind.application-unavailable
                            ? "This app cannot open right now. Its storage or required service is not ready."
                            : ShellData.alert == AlertKind.application-stopped
                                ? "The app closed unexpectedly. ferrink returned safely, and you can choose what to open next."
                                : "ferrink could not keep the app running. The original Amazon home screen will open automatically.";
                        color: #4b4a46;
                        font-size: 20px * root.ui-scale;
                        wrap: word-wrap;
                        overflow: elide;
                        max-lines: 3;
                    }

                    if ShellData.alert == AlertKind.recovery-countdown : Rectangle {
                        height: 112px * root.ui-scale;
                        background: #111111;

                        HorizontalLayout {
                            padding-left: 22px * root.ui-scale;
                            padding-right: 22px * root.ui-scale;

                            Text {
                                text: "\{ShellData.recovery-seconds}";
                                color: white;
                                font-size: 64px * root.ui-scale;
                                font-weight: 800;
                                vertical-alignment: center;
                            }
                            Rectangle { horizontal-stretch: 1; }
                            Text {
                                text: "SECONDS";
                                color: white;
                                font-size: 16px * root.ui-scale;
                                font-weight: 700;
                                letter-spacing: 2px * root.ui-scale;
                                vertical-alignment: center;
                            }
                        }
                    }

                    Rectangle { vertical-stretch: 1; }

                    alert-action := CompactButton {
                        label: ShellData.alert == AlertKind.recovery-countdown ? "Open Kindle now" : "Back to applications";
                        ui-scale: root.ui-scale;
                        dark: ShellData.alert == AlertKind.recovery-countdown;
                        focus-request: root.focus-generation;
                        activated => {
                            if ShellData.alert == AlertKind.recovery-countdown {
                                ShellActions.request-stock();
                            } else {
                                ShellActions.dismiss-alert();
                            }
                        }
                    }
                }
            }

            Rectangle { vertical-stretch: 1; }
        }
    }
    }
}
