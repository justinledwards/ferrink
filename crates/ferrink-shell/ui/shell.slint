        x: 1px * root.ui-scale;
        y: 1px * root.ui-scale;
        width: parent.width;
        height: parent.height;
        text: root.text;
        default-color: #111111;
        default-font-size: root.font-size * 1px * root.ui-scale;
        horizontal-alignment: left;
        vertical-alignment: center;
        max-lines: 24;
    }

    StyledText {
        width: parent.width;
        height: parent.height;
        text: root.text;
        default-color: #f7f6f0;
        default-font-size: root.font-size * 1px * root.ui-scale;
        horizontal-alignment: left;
        vertical-alignment: center;
        max-lines: 24;
    }
}

